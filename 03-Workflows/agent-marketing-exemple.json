{
  "name": "Agent Marketing - Analyse URL et Strategie Contenu",
  "nodes": [
    {
      "parameters": {
        "options": {
          "systemMessage": "Tu es un consultant en marketing digital. Ton role est d'analyser des sites web et de generer des strategies de contenu marketing coherentes. Lorsqu'on te donne une URL, utilise l'outil de recuperation web pour obtenir le contenu de la page, puis analyse-le et produis une strategie comportant : 1) Analyse du secteur et de la cible, 2) Objectifs marketing, 3) Themes de contenu recommandes, 4) Formats suggestes, 5) Planning type. Reponds toujours en francais."
        }
      },
      "id": "agent-001",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [600, 400],
      "typeVersion": 1.1
    },
    {
      "parameters": {},
      "id": "trigger-001",
      "name": "Chat Trigger",
      "type": "@n8n/n8n-nodes-langchain.chatTrigger",
      "position": [380, 400],
      "typeVersion": 1,
      "webhookId": "agent-marketing-chat"
    },
    {
      "parameters": {},
      "id": "memory-001",
      "name": "Simple Memory",
      "type": "@n8n/n8n-nodes-langchain.memoryBufferWindow",
      "position": [600, 600],
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "model": "tinyllama",
        "options": {
          "temperature": 0.7
        }
      },
      "id": "ollama-001",
      "name": "Ollama Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "position": [820, 200],
      "typeVersion": 1
    },
    {
      "parameters": {
        "name": "fetch_url",
        "description": "Recupere le contenu textuel d'une page web a partir de son URL. Utilise cet outil lorsque l'utilisateur fournit une URL a analyser ou lorsque tu as besoin du contenu d'un site pour elaborer une strategie marketing.",
        "method": "GET",
        "url": "placeholder",
        "options": {
          "response": {
            "response": {
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "tool-001",
      "name": "HTTP Request Tool",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "position": [820, 400],
      "typeVersion": 1
    },
    {
      "parameters": {
        "content": "## Configuration requise\n\n1. Installer TinyLlama : ollama pull tinyllama\n2. Creer des identifiants Ollama (Parametres > Identifiants)\n3. URL de base : http://host.docker.internal:11434\n4. Connecter les identifiants au noeud Ollama Chat Model\n5. Modele : tinyllama (ou llama3/mistral)",
        "height": 180,
        "width": 280,
        "color": 2
      },
      "id": "note-001",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "position": [320, 180],
      "typeVersion": 1
    }
  ],
  "pinData": {},
  "connections": {
    "Chat Trigger": {
      "main": [
        [
          {
            "node": "AI Agent",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Simple Memory": {
      "ai_memory": [
        [
          {
            "node": "AI Agent",
            "type": "ai_memory",
            "index": 0
          }
        ]
      ]
    },
    "Ollama Chat Model": {
      "ai_languageModel": [
        [
          {
            "node": "AI Agent",
            "type": "ai_languageModel",
            "index": 0
          }
        ]
      ]
    },
    "HTTP Request Tool": {
      "ai_tool": [
        [
          {
            "node": "AI Agent",
            "type": "ai_tool",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "templateCredsSetupCompleted": false
  }
}
